# Copy this file to .env.local and configure your settings

# ── Docker Container ──────────────────────────────────────────────
# Name of the Minecraft Bedrock container (from docker ps)
CONTAINER_NAME=bds

# ── Docker Connection (choose one) ───────────────────────────────
# Option 1: Unix socket — Linux / macOS / WSL2
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Option 2: Windows Docker Desktop (named pipe) — uncomment to use
# DOCKER_SOCKET_PATH=//./pipe/docker_engine

# Option 3: TCP — if Docker daemon exposes TCP (e.g. remote host)
# DOCKER_HOST=127.0.0.1
# DOCKER_PORT=2375

# ── Panel Authentication ──────────────────────────────────────────
# Password required to access the panel (required)
PANEL_PASSWORD=changeme

# Optional: separate HMAC signing secret (defaults to PANEL_PASSWORD if not set)
# PANEL_SECRET=some-random-secret
